# Optional: loaded by dotenvy when you call `AppConfig::load()` (Sprint 3).
# Values override `purwa.toml` for keys under the `PURWA` prefix.

# Example: override HTTP port (maps to `[server].port`)
# PURWA_SERVER__PORT=8080

# Example: override app display name (maps to `[app].name`)
# PURWA_APP__NAME=my-app
