# Copy to `purwa.toml` in your project root (see PRD §6).
# Env overrides: prefix `PURWA`, nested keys use `__` (e.g. `PURWA_SERVER__PORT=8080`).

[app]
name = "my-purwa-app"

[server]
host = "0.0.0.0"
port = 3000

# Optional: Postgres URL (overridable with PURWA_DATABASE__URL or DATABASE_URL)
# [database]
# url = "postgres://postgres:postgres@127.0.0.1:5432/myapp"
